# Copy this file to .env and fill in your values

# Google Apps Script — contact form → Google Sheet + email
REACT_APP_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Resume (Google Drive view link)
REACT_APP_RESUME_URL=https://drive.google.com/file/d/YOUR_FILE_ID/view?usp=sharing

# Personal info
REACT_APP_EMAIL=your@email.com
REACT_APP_PHONE=+91 XXXXXXXXXX
REACT_APP_GITHUB=https://github.com/your-username
REACT_APP_LINKEDIN=https://www.linkedin.com/in/your-profile
